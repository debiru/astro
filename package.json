{
  "name": "project",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run disableDevToolbar && astro dev",
    "enableDevToolbar": "astro preferences reset devToolbar",
    "disableDevToolbar": "astro preferences disable devToolbar",
    "src-prettier": "prettier --write '{{src,public}/**/*,./*}.{mdx,scss,js,ts,mjs,astro}'",
    "build": "build/pre-build.sh && astro build && build/post-build.sh",
    "watch": "build/watch.sh",
    "stylelint": "build/stylelint.sh",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.0.8"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "js-beautify": "^1.15.4",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
